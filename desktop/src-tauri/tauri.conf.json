{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "WJP Debt Tracking",
  "version": "0.1.0",
  "identifier": "com.pappoeventure.wjp",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../dist",
    "devUrl": "https://wjpdebttracking.com"
  },
  "app": {
    "windows": [
      {
        "title": "WJP Debt Tracking",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "Put a date on debt-free.",
    "longDescription": "WJP Debt Tracking — AI debt coach + bank sync + payoff strategy engine. The exact date you'll be debt-free, in your taskbar."
  }
}
